# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (if using PostgreSQL instead of SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/quotation_db

# Email Settings (for notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Company Settings
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Your Street, Singapore 123456
COMPANY_PHONE=+65 1234 5678
COMPANY_EMAIL=info@yourcompany.com
COMPANY_WEBSITE=https://yourcompany.com

# Default Settings
DEFAULT_TAX_RATE=7.0
DEFAULT_CURRENCY=SGD